# Configurazione frontend (Vite). Copia in .env.local (dev) o .env.production.
# Tutti questi valori sono PUBBLICI (vanno nel bundle del browser): non sono segreti.

# Backend: di norma lascia vuoto (usa il rewrite /api/extract di Firebase Hosting).
# In sviluppo, per puntare all'emulatore Hosting:
# VITE_API_BASE=http://127.0.0.1:5000

# --- Firebase App Check (opzionale ma consigliato) ---
# Dalla Firebase Console → Impostazioni progetto → "Le tue app" (config web)
# e da App Check (provider reCAPTCHA v3). Se NON li imposti, App Check resta
# disattivato e l'app funziona comunque.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_RECAPTCHA_SITE_KEY=
