# Modello usato per l'estrazione. Default: claude-sonnet-4-6 (qualità/costo ottimo).
# Alternative:
#   EXTRACT_MODEL=claude-opus-4-8    # più accurato (più costoso)
#   EXTRACT_MODEL=claude-haiku-4-5   # più economico
EXTRACT_MODEL=claude-sonnet-4-6

# App Check: "true" accetta solo richieste dal tuo sito (token reCAPTCHA verificato).
# Lascia "false" finché non hai configurato App Check + reCAPTCHA, poi metti "true".
ENFORCE_APP_CHECK=false

# Tetto di spesa mensile in EUR su questo endpoint (0 = nessun limite).
# Richiede Firestore attivo: la spesa è tracciata in collezione "usage" / doc "YYYY-MM".
MONTHLY_BUDGET_EUR=20
# Cambio USD→EUR per stimare la spesa (i prezzi Anthropic sono in USD).
USD_PER_EUR=1.08

# NB: la API key NON va qui. Si imposta come secret:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
